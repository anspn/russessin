{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Russessin - loginctl REST API",
		"description": "Complete API collection for the Russessin service, which exposes Linux loginctl commands as REST endpoints.\n\n## Configuration\n\nSet the `base_url` variable to point to your running instance (default: `http://127.0.0.1:3000`).\n\nSet `session_id` and `user_uid` variables to match real values from your system (use the List Sessions / List Users requests first to discover them).\n\n## Endpoints\n\n- **Health Check** — verify the service is running\n- **Sessions** — list, show, status, activate, lock, unlock, terminate, kill\n- **Users** — list, show, status, enable/disable linger, terminate, kill",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:3000",
			"type": "string"
		},
		{
			"key": "session_id",
			"value": "1",
			"type": "string",
			"description": "Session ID to use for single-session operations. Run 'List Sessions' first to find valid IDs."
		},
		{
			"key": "user_uid",
			"value": "1000",
			"type": "string",
			"description": "User UID to use for single-user operations. Run 'List Users' first to find valid UIDs."
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/healthz",
							"host": ["{{base_url}}"],
							"path": ["healthz"]
						},
						"description": "Verify that the russessin service is running and healthy.\n\nReturns `200 OK` with body `ok`."
					},
					"response": [
						{
							"name": "Healthy",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/healthz",
									"host": ["{{base_url}}"],
									"path": ["healthz"]
								}
							},
							"status": "OK",
							"code": 200,
							"body": "ok"
						}
					]
				}
			],
			"description": "Service health endpoint"
		},
		{
			"name": "Sessions",
			"item": [
				{
					"name": "List Sessions",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test('Auto-set session_id from first result', function () {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.length > 0) {",
									"        pm.collectionVariables.set('session_id', jsonData[0].id);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/sessions",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "sessions"]
						},
						"description": "List all active login sessions.\n\nEquivalent to `loginctl list-sessions`.\n\nReturns an array of session summary objects with `id`, `uid`, `user`, `seat`, and `path` fields.\n\n**Note:** The test script automatically sets the `session_id` collection variable from the first result."
					},
					"response": [
						{
							"name": "Sessions Found",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/api/v1/sessions",
									"host": ["{{base_url}}"],
									"path": ["api", "v1", "sessions"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "[\n  {\n    \"id\": \"1\",\n    \"uid\": 1000,\n    \"user\": \"alice\",\n    \"seat\": \"seat0\",\n    \"path\": \"/org/freedesktop/login1/session/_31\"\n  }\n]"
						}
					]
				},
				{
					"name": "Show Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has session properties', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('uid');",
									"    pm.expect(jsonData).to.have.property('state');",
									"    pm.expect(jsonData).to.have.property('active');",
									"    pm.expect(jsonData).to.have.property('type');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/sessions/{{session_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "sessions", "{{session_id}}"]
						},
						"description": "Show detailed properties of a specific session.\n\nEquivalent to `loginctl show-session <id>`.\n\nReturns a `SessionProperties` object with fields: `id`, `uid`, `user`, `seat`, `type`, `class`, `active`, `state`, `remote`, `remote_host`, `remote_user`, `service`, `desktop`, `scope`, `leader`, `audit`, `vt_nr`, `tty`, `display`, `timestamp`."
					},
					"response": [
						{
							"name": "Session Properties",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/api/v1/sessions/{{session_id}}",
									"host": ["{{base_url}}"],
									"path": ["api", "v1", "sessions", "{{session_id}}"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [{"key": "Content-Type", "value": "application/json"}],
							"body": "{\n  \"id\": \"1\",\n  \"uid\": 1000,\n  \"user\": \"alice\",\n  \"seat\": \"seat0\",\n  \"type\": \"x11\",\n  \"class\": \"user\",\n  \"active\": true,\n  \"state\": \"active\",\n  \"remote\": false,\n  \"remote_host\": \"\",\n  \"remote_user\": \"\",\n  \"service\": \"gdm-password\",\n  \"desktop\": \"gnome\",\n  \"scope\": \"session-1.scope\",\n  \"leader\": 1234,\n  \"audit\": 1,\n  \"vt_nr\": 2,\n  \"tty\": \"\",\n  \"display\": \":0\",\n  \"timestamp\": 1713523200000000\n}"
						}
					]
				},
