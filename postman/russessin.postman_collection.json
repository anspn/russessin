								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"signal\": \"SIGKILL\",\n  \"who\": \"leader\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/sessions/{{session_id}}/kill",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "sessions", "{{session_id}}", "kill"]
						},
						"description": "Kill only the session leader process with SIGKILL. Example variation of the Kill Session endpoint."
					},
					"response": []
				}
