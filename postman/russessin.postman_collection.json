						}
					],
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/sessions/{{session_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "sessions", "{{session_id}}"]
						},
						"description": "Terminate a specific session, killing all processes in it.\n\nEquivalent to `loginctl terminate-session <id>`.\n\n⚠️ **Destructive operation** — this will end the user's session.\n\nReturns `204 No Content` on success."
					},
					"response": []
				},
				{
					"name": "Kill Session",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 204', function () {",
									"    pm.response.to.have.status(204);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"signal\": \"SIGTERM\",\n  \"who\": \"all\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/sessions/{{session_id}}/kill",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "sessions", "{{session_id}}", "kill"]
						},
						"description": "Send a signal to processes in a specific session.\n\nEquivalent to `loginctl kill-session <id> --signal=<signal> --kill-who=<who>`.\n\n### Request Body\n\n| Field    | Type   | Default     | Description |\n|----------|--------|-------------|-------------|\n| `signal` | string | `\"SIGTERM\"` | Signal name (e.g. `SIGTERM`, `SIGKILL`, `TERM`, `9`) or number |\n| `who`    | string | `\"all\"`     | Which processes to signal: `\"leader\"` or `\"all\"` |\n\n⚠️ **Destructive operation** — sending `SIGKILL` cannot be caught by processes.\n\nReturns `204 No Content` on success."
					},
					"response": []
				},
				{
					"name": "Kill Session (leader only, SIGKILL)",
					"request": {
						"method": "POST",
						"header": [
